digraph guest_register {
    rankdir=TB;
    nodesep=0.5;
    ranksep=1.5;

    node [shape=box, style=rounded]
    End [shape=oval]

    RegisterGuest
    RetrieveGuest

    RegisterGuest -> RetrieveGuest [weight=1.0]
    RetrieveGuest -> End [weight=1.0]

    { rank=source; Init }
    { rank=sink; End }
}
