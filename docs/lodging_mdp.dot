digraph GuestJourney {
    graph [
        rankdir=LR,
        splines=true,
        nodesep=0.5,
        ranksep=1.0,
        fontname="Helvetica"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fontname="Helvetica",
        color="#2e3440",
        fillcolor="#f8f5ef"
    ];

    edge [
        fontname="Helvetica",
        color="#5e6b73"
    ];

    start [shape=circle, width=0.18, label="", fillcolor="#2e3440", color="#2e3440"];
    done [shape=doublecircle, label="Journey complete", fillcolor="#d9f0d8"];

    subgraph cluster_booking_payment {
        label="Booking + Payment";
        color="#8fb0d9";
        style="rounded";

        create_profile [label="Guest profile created\nwith billing address"];
        prepare_booking [label="Same-day booking picked\ncheck-in today\ncheck-out tomorrow+"];
        booking_created [label="Booking created\nstatus: pending"];
        invoice_wait [label="Payment reissue polling:\nwait until invoice exists"];
        invoice_found [label="Invoice available\nfor booking"];
        pay_invoice [label="Guest pays invoice\ncredit card endpoint"];
        payment_ok [label="Payment succeeded"];
        booking_confirmed [label="GuestManager polling:\nbooking status = confirmed"];
    }

    subgraph cluster_checkin {
        label="Check-in";
        color="#d8c39a";
        style="rounded";

        arrival [label="Guest shows up\nat resort"];
        show_for_checkin [label="Guest action:\nSHOW_FOR_CHECKIN\n15:00 UTC"];
        request_document [label="System request:\nREQUEST_DOCUMENT"];
        show_document [label="Guest reply:\nshow document"];
        booking_checking [label="System notification:\nBOOKING_CHECKING"];
        fallback_booking [label="Optional fallback:\nREQUEST_BOOKING_NUMBER\n-> show booking id"];
        checkin_complete [label="System notification:\nCHECK_IN_COMPLETE"];
        give_key [label="System request:\nGIVE_COTTAGE_KEY"];
        receive_key [label="Guest reply:\nreceive key id"];
        take_key [label="Guest action:\nTAKE_COTTAGE_KEY"];
    }

    subgraph cluster_stay {
        label="Stay";
        color="#9ec5c4";
        style="rounded";

        enter_cottage [label="Guest action:\nENTER_COTTAGE"];
        bath_checkin [label="Guest action:\nGO_FOR_A_BATH\nnot before 16:00"];
        dinner_ready_checkin [label="System notification:\nDINNER_READY"];
        dinner_checkin [label="Guest action:\nGO_FOR_DINNER\nnot before 18:00"];
        sleep_checkin [label="Guest action:\nGO_TO_SLEEP\nnot before 22:00"];

        wakeup [label="Guest action:\nWAKEUP\nnot before 07:00"];
        breakfast_ready [label="System notification:\nBREAKFAST_READY"];
        breakfast [label="Guest action:\nGO_FOR_BREAKFAST\nnot before 08:00"];
        cleanup_notice [label="Guest action:\nLEAVE_CLEANUP_NOTIFICATION\nnot before 10:00"];
        enjoy_resort [label="Guest action:\nENJOY_RESORT\nnot before 11:00"];
        bath_day [label="Guest action:\nGO_FOR_A_BATH\nnot before 16:00"];
        dinner_ready_day [label="System notification:\nDINNER_READY"];
        dinner_day [label="Guest action:\nGO_FOR_DINNER\nnot before 18:00"];
        sleep_day [label="Guest action:\nGO_TO_SLEEP\nnot before 22:00"];
        extra_days [shape=diamond, fillcolor="#fff3cd", label="More full stay days?"];
    }

    subgraph cluster_checkout {
        label="Checkout";
        color="#d7a4a4";
        style="rounded";

        checkout_today [label="System notification:\nCHECK_OUT_TODAY"];
        leave_cottage [label="Guest action:\nLEAVE_COTTAGE"];
        proceed_checkout [label="Guest action:\nPROCEED_TO_CHECKOUT"];
        request_return_key [label="System request:\nREQUEST_COTTAGE_KEY"];
        reply_return_key [label="Guest reply:\nreturn key id"];
        return_key [label="Guest action:\nRETURN_COTTAGE_KEY"];
        checkout_complete [label="System notification:\nCHECK_OUT_COMPLETE"];
    }

    start -> create_profile;
    create_profile -> prepare_booking [label="register guest"];
    prepare_booking -> booking_created [label="book cottage"];
    booking_created -> invoice_wait [label="cottageManager publishes\ncreate-invoice"];
    invoice_wait -> invoice_found [label="paymentSimulator reissue succeeds"];
    invoice_found -> pay_invoice [label="invoice_number ready"];
    pay_invoice -> payment_ok [label="POST /v1/payments/invoice/{invoice}"];
    payment_ok -> booking_confirmed [label="payment confirmation fanout"];
    booking_confirmed -> arrival [label="only then start lodging"];
    arrival -> show_for_checkin [label="arrival window opens"];
    show_for_checkin -> request_document [label="websocket check-in starts"];
    request_document -> show_document [label="required"];
    show_document -> booking_checking [label="document submitted"];
    booking_checking -> checkin_complete [label="booking found for today"];
    booking_checking -> fallback_booking [label="default lookup failed"];
    fallback_booking -> checkin_complete [label="fallback booking accepted"];
    checkin_complete -> give_key [label="reception proceeds"];
    give_key -> receive_key [label="guest sends key id"];
    receive_key -> take_key [label="handoff complete"];

    take_key -> enter_cottage [label="causal gate:\nonly after key handoff"];
    enter_cottage -> bath_checkin [label="check-in day routine"];
    bath_checkin -> dinner_ready_checkin [style=dashed, label="wait for system dinner bell"];
    dinner_ready_checkin -> dinner_checkin [label="hour >= 18:00"];
    dinner_checkin -> sleep_checkin [label="hour >= 22:00"];

    sleep_checkin -> extra_days [label="first night finished"];
    extra_days -> wakeup [label="yes"];
    wakeup -> breakfast_ready [style=dashed, label="wait for system breakfast bell"];
    breakfast_ready -> breakfast [label="hour >= 08:00"];
    breakfast -> cleanup_notice [label="hour >= 10:00"];
    cleanup_notice -> enjoy_resort [label="hour >= 11:00"];
    enjoy_resort -> bath_day [label="hour >= 16:00"];
    bath_day -> dinner_ready_day [style=dashed, label="wait for system dinner bell"];
    dinner_ready_day -> dinner_day [label="hour >= 18:00"];
    dinner_day -> sleep_day [label="hour >= 22:00"];
    sleep_day -> extra_days [label="repeat next full stay day"];

    extra_days -> checkout_today [label="no"];
    checkout_today -> leave_cottage [label="checkout gate opens"];
    leave_cottage -> proceed_checkout [label="guest heads to reception"];
    proceed_checkout -> request_return_key [label="system asks for key"];
    request_return_key -> reply_return_key [label="guest sends key id"];
    reply_return_key -> return_key [label="request satisfied"];
    return_key -> checkout_complete [label="checkout finalizes"];
    checkout_complete -> done;
}
